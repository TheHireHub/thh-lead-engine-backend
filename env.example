# THH Lead Engine Backend — environment variables
# Copy to .env and fill in real values.

# Flask
SECRET_KEY=dev-secret-key-change-me
FLASK_ENV=development
PORT=5050

# Cookies / sessions
SESSION_COOKIE_SECURE=False

# JWT (admin auth)
JWT_SECRET_KEY=dev-jwt-secret-change-me
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24

# MySQL — same server as thh-backend, separate database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=thh_lead_engine

# Redis (ARQ + cache)
REDIS_URL=redis://localhost:6379/0

# THH backend integration (touch points 1-5 from schema doc §9)
THH_BACKEND_BASE_URL=http://localhost:5000
THH_BACKEND_SERVICE_TOKEN=

# Apollo
APOLLO_API_KEY=
APOLLO_SYNC_INTERVAL_HOURS=6

# Calendly
CALENDLY_WEBHOOK_SIGNING_KEY=

# Telegram alerts (separate channel from THH)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Sentry (optional)
SENTRY_DSN=

# Webhook security
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Visitor IP hashing
VISITOR_IP_HASH_SECRET=dev-ip-hash-secret-change-me
