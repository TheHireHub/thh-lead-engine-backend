# =============================================================================
# THH Lead Engine — Backend environment variables
# =============================================================================
# Copy to .env and fill in real values:
#     cp env.example .env
#
# Required-vs-optional and dev-vs-prod values are called out per section.
# In production (APP_ENV=production), the app validates required secrets at
# startup and refuses to boot if any are missing or use "change-me" defaults.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Runtime mode
# -----------------------------------------------------------------------------
# APP_ENV gates several behaviours:
#   - development → /docs is exposed, error tracebacks leak in 500 responses,
#                   secret defaults are tolerated.
#   - production  → /docs hidden, error responses generic, secret defaults
#                   FAIL startup, SESSION_COOKIE_SECURE must be True.
APP_ENV=development

# Optional: set EXPOSE_DOCS=true in prod to re-enable /docs (e.g. behind VPN).
EXPOSE_DOCS=false

PORT=5050


# -----------------------------------------------------------------------------
# 2. JWT — admin auth (REQUIRED in prod)
# -----------------------------------------------------------------------------
# Generate a strong secret in prod:
#     python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=dev-jwt-secret-change-me
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24


# -----------------------------------------------------------------------------
# 3. Cookies / session
# -----------------------------------------------------------------------------
# Dev (HTTP localhost): Secure=False, Domain empty, SameSite=lax
# Prod (FE on try-thehirehub.com, API on api.try-thehirehub.com):
#     SESSION_COOKIE_SECURE=True
#     SESSION_COOKIE_DOMAIN=.thehirehub.com
#     SESSION_COOKIE_SAMESITE=lax
#
# When the FE proxies /api/* through Next.js (same-origin), Domain can stay
# empty and SameSite=lax is sufficient.
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAMESITE=lax


# -----------------------------------------------------------------------------
# 4. CORS (REQUIRED in prod)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed FE origins. No trailing slashes.
# Dev default is localhost:3000 + 3001.
# Prod example:
#     CORS_ALLOWED_ORIGINS=https://try-thehirehub.com,https://www.try-thehirehub.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001


# -----------------------------------------------------------------------------
# 5. MySQL (REQUIRED)
# -----------------------------------------------------------------------------
# Logically separate database from thh-backend (no shared tables).
# In dev, create a user with: GRANT ALL ON thh_lead_engine.* TO 'thh_user'@'%';
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=thh_user
MYSQL_PASSWORD=thh_password
MYSQL_DB=thh_lead_engine

# Optional: set to true to log every SQL statement (very noisy).
SQL_ECHO=false


# -----------------------------------------------------------------------------
# 6. Redis — ARQ task queue (REQUIRED for workers)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0


# -----------------------------------------------------------------------------
# 7. Container entrypoint hooks
# -----------------------------------------------------------------------------
# In Docker, set RUN_MIGRATIONS=1 on the API container so it runs
# "alembic upgrade head" before starting gunicorn. Don't set this on worker
# containers (only one process should run migrations).
RUN_MIGRATIONS=0
MYSQL_WAIT_TIMEOUT=60


# -----------------------------------------------------------------------------
# 8. THH backend integration (touch points 1-5 from schema doc §9)
# -----------------------------------------------------------------------------
# Internal URL for service-to-service calls. In prod this is typically a VPC
# private hostname, not the public domain.
THH_BACKEND_BASE_URL=http://localhost:5000
THH_BACKEND_SERVICE_TOKEN=

# Inbound service token for THH → LEADS pushes (Initiate Outreach webhook,
# §9.6). Distinct from THH_BACKEND_SERVICE_TOKEN (outbound) so a leak in
# one direction doesn't pivot to the other and rotations stay independent.
# REQUIRED — the /api/candidate-outreach/ingest endpoint fails closed
# (returns 503) if this is unset, so HH-BE cannot push without it.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
THH_INCOMING_SERVICE_TOKEN=


# -----------------------------------------------------------------------------
# 9. Apollo (optional — outbound prospect sync)
# -----------------------------------------------------------------------------
APOLLO_API_KEY=
APOLLO_SYNC_INTERVAL_HOURS=6
# JSON blob describing the Ideal Customer Profile filter (see schema §9.2).
APOLLO_ICP_FILTER_JSON=
# HMAC signing key for inbound Apollo webhooks (REQUIRED if Apollo posts to us).
APOLLO_WEBHOOK_SIGNING_KEY=


# -----------------------------------------------------------------------------
# 10. Calendly (optional)
# -----------------------------------------------------------------------------
CALENDLY_WEBHOOK_SIGNING_KEY=


# -----------------------------------------------------------------------------
# 11. Telegram alerts (optional — separate channel from THH)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# -----------------------------------------------------------------------------
# 12. Sentry (optional — error tracking)
# -----------------------------------------------------------------------------
SENTRY_DSN=


# -----------------------------------------------------------------------------
# 13. Webhook security (REQUIRED if any inbound webhooks are configured)
# -----------------------------------------------------------------------------
# Reject webhooks whose timestamp is more than this many seconds old.
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300


# -----------------------------------------------------------------------------
# 14. Visitor PII hashing (REQUIRED in prod — Arch-26)
# -----------------------------------------------------------------------------
# We never store raw IPs. Stored value = sha256(ip + this_secret).
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
VISITOR_IP_HASH_SECRET=dev-ip-hash-secret-change-me


# -----------------------------------------------------------------------------
# 15. Unsubscribe tokens (REQUIRED if outbound emails are sent)
# -----------------------------------------------------------------------------
# HMAC key for one-click unsubscribe links (RFC 8058 List-Unsubscribe header).
# If unset, every token will fail verification (so unsub links break silently).
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
UNSUBSCRIBE_TOKEN_SECRET=
